# Host Address of APM Monitoring Route Server Container
APM_MONITOR=http://apmserver01:5066

# Host Address of APM Server Container
APM_HOST=http://apmserver01:8200

# Host Address of Elastic Search Container
ELASTIC_HOST=https://es01:9200

# Host Address of Heartbeat Container
HEARTBEAT_HOST=http://heartbeat01:5067

# Host Address of Filebeat Container
FILEBEAT_HOST=http://filebeat01:5066

# Host Address of Kibana Container
KIBANA_HOST=http://kibana:5601

# Username for the 'kibana_admin' user 
KIBANA_USERNAME=kibana_admin

# Password for the 'kibana_admin' user (at least 6 characters)
KIBANA_PASSWORD=kibana

# Password for the 'elastic' user (at least 6 characters)
ELASTIC_PASSWORD=elastic

# Password for the 'kibana_system' user (at least 6 characters)
KIBANA_PASSWORD=kibana

# Version of Elastic products
STACK_VERSION=9.1.3

# Set the cluster name
CLUSTER_NAME=jeferson-cluster

# Set to 'basic' or 'trial' to automatically start the 30-day trial
LICENSE=basic
#LICENSE=trial

# Port to expose APM Server HTTP API to the host
APM_MONITORING_PORT=5066

# Port to expose APM Server HTTP API to the host
APM_PORT=8200

# Port to expose Filebeat HTTP API to the host
FB_PORT=5066

# Port to expose Heartbeat HTTP API to the host
HB_PORT=5067

# Port to expose Elasticsearch HTTP API to the host
ES_PORT=9200
#ES_PORT=127.0.0.1:9200

# Port to expose Kibana to the host
KIBANA_PORT=5601
#KIBANA_PORT=80

# Increase or decrease based on the available host memory (in bytes)
MEM_LIMIT=1073741824

# Project namespace (defaults to the current folder name if not set)
#COMPOSE_PROJECT_NAME=myproject

# SAMPLE Predefined Key only to be used in POC environments
ENCRYPTION_KEY=c34d38b3a14956121ff2170e5030b471551370178f43e5626eec58b04a30fae2